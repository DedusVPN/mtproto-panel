frontend/node_modules/
frontend/dist/
frontend/.cache/
frontend/.vite/

# Документация и утилиты, не нужные в образе
*.md
!README.md
scripts/
config/
deploy/init_docker_secrets.sh
deploy/Dockerfile

# Прочее
*.cmd
double-hop-xray.txt
instr.txt
