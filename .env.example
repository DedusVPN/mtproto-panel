# Скопируйте в .env и заполните. Файл .env в .gitignore.
# Сценарий: доступ к панели по http://<IP>:<порт> без домена и SSL.
# Docker: deploy/Dockerfile, deploy/init_docker_secrets.sh, docker-compose.yml в корне.

DATABASE_URL=postgresql+asyncpg://panel:panel@localhost:5432/panel

# Данные PostgreSQL для Docker
POSTGRES_USER=panel
POSTGRES_PASSWORD=panel
POSTGRES_DB=panel

# VDSina User API (опционально)
# VDSINA_API_TOKEN=
# VDSINA_API_BASE=https://userapi.vdsina.com/v1

# Cloudflare DNS (опционально): API Token — Zone.DNS Edit + Zone.Zone Read
# CLOUDFLARE_API_TOKEN=
# Зона: либо id, либо имя корневого домена
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_ZONE_NAME=example.com
# Скрипт одной A-группы: uv run python scripts/cloudflare_sync_dns.py --dry-run --name mt --ips 1.1.1.1

# --- Аутентификация панели (JWT + cookie HttpOnly) ---
# PANEL_AUTH_ENABLED=true
# PANEL_JWT_SECRET=  # ≥32 символа; в Docker: PANEL_JWT_SECRET_FILE=/run/secrets/panel_jwt_secret
# PANEL_JWT_EXPIRE_MINUTES=480
# PANEL_ADMIN_USERNAME=admin
# bcrypt: uv run python scripts/gen_panel_password_hash.py
# PANEL_ADMIN_PASSWORD_HASH=
# PANEL_ADMIN_PASSWORD_HASH_FILE=/run/secrets/panel_admin_password_hash

# Без HTTPS (доступ по IP:порт) — обязательно false, иначе браузер не отправит cookie сессии:
# PANEL_COOKIE_SECURE=false
# За reverse-proxy с TLS включите true и PANEL_TRUST_FORWARDED_PROTO=true
# PANEL_TRUST_FORWARDED_PROTO=false
# PANEL_COOKIE_SAMESITE=lax

# Только если UI с другого origin:
# PANEL_CORS_ORIGINS=
# PANEL_EXPOSE_OPENAPI=false

# Слушать интерфейс (run_panel.sh / .cmd): по умолчанию 0.0.0.0 — доступ по IP сервера
# PANEL_BIND_HOST=0.0.0.0
# PANEL_BIND_PORT=8765
