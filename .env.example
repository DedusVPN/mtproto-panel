# Скопируйте в .env и заполните. Файл .env в .gitignore.
# Docker: deploy/Dockerfile, deploy/init_docker_secrets.sh, docker-compose.yml в корне.

# VDSina User API (опционально)
# VDSINA_API_TOKEN=
# VDSINA_API_BASE=https://userapi.vdsina.com/v1

# --- Аутентификация панели (JWT + cookie HttpOnly) ---
# Включить защиту API и WebSocket:
# PANEL_AUTH_ENABLED=true
# Секрет подписи JWT (≥32 символа). В Docker удобнее файл:
# PANEL_JWT_SECRET=
# PANEL_JWT_SECRET_FILE=/run/secrets/panel_jwt_secret
# PANEL_JWT_EXPIRE_MINUTES=480
# PANEL_ADMIN_USERNAME=admin
# Рекомендуется bcrypt: uv run python scripts/gen_panel_password_hash.py
# PANEL_ADMIN_PASSWORD_HASH=
# PANEL_ADMIN_PASSWORD_HASH_FILE=/run/secrets/panel_admin_password_hash
# Только для отладки (не для продакшена):
# PANEL_ADMIN_PASSWORD=
# За HTTPS-терминатором:
# PANEL_COOKIE_SECURE=true
# PANEL_TRUST_FORWARDED_PROTO=true
# PANEL_COOKIE_SAMESITE=lax
# CORS (через запятую); пусто — middleware CORS не используется (типично same-origin):
# PANEL_CORS_ORIGINS=
# Открыть /docs без входа (не рекомендуется):
# PANEL_EXPOSE_OPENAPI=false
